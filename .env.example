# Database
# Use the pooled connection string for DATABASE_URL (usually port 5432 or 6543)
DATABASE_URL=postgres://impenetrable:password@localhost:5432/impenetrable_db
# Use the unpooled connection string for DIRECT_URL (required for migrations)
DIRECT_URL=postgres://impenetrable:password@localhost:5432/impenetrable_db

# Logging
LOG_BODY=true
PORT=3000
