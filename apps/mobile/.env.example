# Mobile App Environment Variables (Example Template)
# Copy this file to .env and fill in the values.
# Expo automatically loads .env files and variables prefixed with EXPO_PUBLIC_

# Toggle Frontend-First Mock Mode (true/false)
EXPO_PUBLIC_USE_MOCKS=true

# Backend API URL (for RestProjectService usage)
# Local dev: http://localhost:3000/v1
# Staging: https://api-staging.impenetrableconnect.com/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/v1

# GitHub Configuration for System Status CI/CD Checks
# The repository to fetch workflow runs from (e.g., masch/impenetrable-connect)
EXPO_PUBLIC_GITHUB_REPO=masch/impenetrable-connect

# GitHub Personal Access Token to avoid IP rate limiting (60 req/hr)
# Generate one at https://github.com/settings/tokens
EXPO_PUBLIC_GITHUB_TOKEN=ghp_your_token_here
