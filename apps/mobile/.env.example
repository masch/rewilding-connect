# Mobile App Environment Variables (Example Template)
# Copy this file to .env and fill in the values.
# Expo automatically loads .env files and variables prefixed with EXPO_PUBLIC_

# Toggle Frontend-First Mock Mode (true/false)
EXPO_PUBLIC_USE_MOCKS=true

# Backend API URL (for RestProjectService usage)
# Local dev: http://localhost:3000/v1
# Staging: https://api-staging.impenetrableconnect.com/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/v1
