{
  "name": "impenetrable-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "start": "expo start --go",
    "start:native": "expo start",
    "start:clean": "expo start -c --go",
    "web": "expo start --web",
    "android": "expo start --go --android",
    "android:native": "expo run:android",
    "ios": "expo start --go --ios",
    "ios:native": "expo run:ios",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "expo:fix:deps": "expo install --fix"
  },
  "dependencies": {
    "@expo/metro-config": "~55.0.9",
    "@repo/shared": "workspace:*",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-status-bar": "~55.0.5",
    "i18n-js": "^4.5.3",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css-interop": "^0.2.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}